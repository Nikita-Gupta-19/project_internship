# Server Configuration
PORT=5050
NODE_ENV=development

# Database Configuration
# format: postgresql://username:password@host:5432/dbname
# Railway provides this automatically as DATABASE_URL when you add a Postgres plugin
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_task_manager

# Authentication
JWT_SECRET=your_super_secret_key_change_in_production

# CORS — comma-separated list of allowed origins (only used in production)
# Leave empty in development (all origins allowed)
# Example: https://yourapp.com,https://staging.yourapp.com
ALLOWED_ORIGINS=

# Gmail SMTP Credentials (App Password required, not normal password)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_character_app_password
